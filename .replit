# Replit configuration — tells Replit how to run the Nampo backend.
run = "cd backend && pip install -r requirements.txt && uvicorn server:app --host 0.0.0.0 --port $PORT --reload"

# Python module system
modules = ["python-3.11"]

[[ports]]
localPort = 8080
externalPort = 8080

[env]
# Replit provides $PORT at runtime; the app binds to it.
PORT = "8080"
DB_NAME = "nampo"
CORS_ORIGINS = "*"
# Do NOT put MONGO_URL here. Add it as a Secret (lock icon) so it stays private.

[nix]
channel = "stable-23_11"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && pip install -r requirements.txt -q && uvicorn server:app --host 0.0.0.0 --port 8080"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"
