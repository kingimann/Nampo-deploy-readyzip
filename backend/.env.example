# ---- Backend environment variables ----
# Copy to ".env" for local dev. In AWS App Runner, set these in the
# console (Configuration -> Environment variables) instead of committing them.

# MongoDB Atlas connection string.
# Atlas -> Database -> Connect -> Drivers -> Python. Replace <password>.
# Make sure the DB user has readWrite and your Network Access allows App Runner.
MONGO_URL=mongodb+srv://USER:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Logical database name used by the app.
DB_NAME=nampo

# Comma-separated list of allowed CORS origins, or "*" for any.
# For production, set this to your frontend's URL(s), e.g.:
#   CORS_ORIGINS=https://app.nampo.com,https://nampo.com
CORS_ORIGINS=*

# Foursquare Places API key (optional — only used by /foursquare routes).
# Leave blank to disable place matching.
FSQ_API_KEY=

# Port App Runner provides. Defaults to 8080 if unset.
PORT=8080
